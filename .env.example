# GetStream
NEXT_PUBLIC_STREAM_KEY=
STREAM_SECRET=

# Resend
RESEND_API_KEY=
EMAIL_FROM=BabyBrain <onboarding@resend.dev>

# Internal
WEBHOOK_SHARED_SECRET=
# Set on Vercel for email links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (Phase 2 vendor billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
